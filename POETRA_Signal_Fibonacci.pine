//@version=5
// =====================================================================
//  POETRA Signal + Fibonacci TP  (shorttitle: POETRA SA)
//  SEJALAN dengan dashboard POETRA (UT Bot key=0.8 / ATR=8) + TP Fibonacci
//  Menggantikan script "Stocks Algo" lama (ATR22x3) yang TIDAK sinkron
//  dengan sinyal UT Bot di dashboard.
//
//  Logika:
//   - Sinyal = UT Bot Alerts (ATR trailing stop) : key(sensitivitas)=0.8, ATR period=8
//     -> identik dengan arrow BUY/SELL di dashboard.
//   - Setiap sinyal BUY/SELL langsung menggambar: Entry, Stop Loss,
//     TP1, TP2, TP3 berbasis proyeksi Fibonacci dari swing (lookback 80).
//       TP = Entry +/- (0.618 / 1.0 / 1.618) x range_swing
//       SL = struktur swing (14 bar) +/- 0.3xATR14
// =====================================================================
indicator('POETRA Signal + Fibonacci TP', shorttitle='POETRA SA', overlay=true)

// ---------- Inputs ----------
grpSig  = 'Sinyal (UT Bot)'
keyVal  = input.float(0.8, 'Sensitivity (key)', step=0.1, group=grpSig)
atrLen  = input.int(8,     'ATR Period',        group=grpSig)

grpFib  = 'Target (Fibonacci)'
swingLB = input.int(80,    'Swing Lookback',    group=grpFib)
f1      = input.float(0.618,'TP1 x range',      step=0.1, group=grpFib)
f2      = input.float(1.0,  'TP2 x range',      step=0.1, group=grpFib)
f3      = input.float(1.618,'TP3 x range',      step=0.1, group=grpFib)

grpVis  = 'Tampilan'
showLbl = input.bool(true, 'Tampilkan garis Entry/SL/TP', group=grpVis)
awaitBar= input.bool(true, 'Tunggu candle close (konfirmasi)', group=grpVis)

// ---------- UT Bot ATR trailing stop (sama persis dengan dashboard utStops) ----------
xATR  = ta.atr(atrLen)
nLoss = keyVal * xATR

var float st = na
st := na(st[1]) ? close - nLoss :
     (close > st[1] and close[1] > st[1]) ? math.max(st[1], close - nLoss) :
     (close < st[1] and close[1] < st[1]) ? math.min(st[1], close + nLoss) :
     (close > st[1]) ? close - nLoss : close + nLoss

buySignal  = close > st and close[1] <= st[1]
sellSignal = close < st and close[1] >= st[1]

plotshape(buySignal,  title='BUY',  text='BUY',  style=shape.labelup,   location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.tiny)
plotshape(sellSignal, title='SELL', text='SELL', style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0),   textcolor=color.white, size=size.tiny)

// ---------- Swing range (Fibonacci) ----------
atr14 = ta.atr(14)
hi    = ta.highest(high, swingLB)
lo    = ta.lowest(low,  swingLB)
rng   = hi - lo

// ---------- Gambar Entry / SL / TP1 / TP2 / TP3 tiap sinyal ----------
var line  eL=na,  slL=na, t1L=na, t2L=na, t3L=na
var label eB=na,  slB=na, t1B=na, t2B=na, t3B=na

f_clear() =>
    line.delete(eL)
    line.delete(slL)
    line.delete(t1L)
    line.delete(t2L)
    line.delete(t3L)
    label.delete(eB)
    label.delete(slB)
    label.delete(t1B)
    label.delete(t2B)
    label.delete(t3B)

trig = (buySignal or sellSignal) and (awaitBar ? barstate.isconfirmed : true)

if showLbl and trig
    f_clear()
    x2    = bar_index + 40
    isBuy = buySignal
    entry = close
    swLo  = ta.lowest(low, 14)
    swHi  = ta.highest(high, 14)
    sl    = isBuy ? math.min(swLo, entry - atr14) - 0.3 * atr14 : math.max(swHi, entry + atr14) + 0.3 * atr14
    tp1   = isBuy ? entry + f1 * rng : entry - f1 * rng
    tp2   = isBuy ? entry + f2 * rng : entry - f2 * rng
    tp3   = isBuy ? entry + f3 * rng : entry - f3 * rng
    tag   = isBuy ? 'BUY' : 'SELL'

    eL  := line.new(bar_index, entry, x2, entry, color=color.blue, width=2)
    slL := line.new(bar_index, sl,   x2, sl,   color=color.red,  width=2)
    t1L := line.new(bar_index, tp1,  x2, tp1,  color=color.new(color.green, 0), width=1, style=line.style_dashed)
    t2L := line.new(bar_index, tp2,  x2, tp2,  color=color.new(color.green, 0), width=1, style=line.style_dashed)
    t3L := line.new(bar_index, tp3,  x2, tp3,  color=color.new(color.green, 0), width=1, style=line.style_dashed)

    eB  := label.new(x2, entry, 'Entry ' + tag + '\n' + str.tostring(entry, format.mintick), style=label.style_label_left, color=color.blue, textcolor=color.white, size=size.small)
    slB := label.new(x2, sl,   'SL '  + str.tostring(sl,  format.mintick), style=label.style_label_left, color=color.red,   textcolor=color.white, size=size.small)
    t1B := label.new(x2, tp1,  'TP1 ' + str.tostring(tp1, format.mintick), style=label.style_label_left, color=color.green, textcolor=color.white, size=size.small)
    t2B := label.new(x2, tp2,  'TP2 ' + str.tostring(tp2, format.mintick), style=label.style_label_left, color=color.green, textcolor=color.white, size=size.small)
    t3B := label.new(x2, tp3,  'TP3 ' + str.tostring(tp3, format.mintick), style=label.style_label_left, color=color.green, textcolor=color.white, size=size.small)

// ---------- EMA (sama seperti dashboard) ----------
plot(ta.ema(close, 20),  'EMA20',  color=color.new(#ffd15c, 0), linewidth=1)
plot(ta.ema(close, 50),  'EMA50',  color=color.new(#2f8fff, 0), linewidth=1)
plot(ta.ema(close, 200), 'EMA200', color=color.new(#ff4d6d, 0), linewidth=1)

// ---------- Alerts ----------
await = awaitBar ? barstate.isconfirmed : true
alertcondition(buySignal  and await, title='POETRA BUY',  message='POETRA BUY - Entry + TP1/TP2/TP3 (Fibonacci)')
alertcondition(sellSignal and await, title='POETRA SELL', message='POETRA SELL - Entry + TP1/TP2/TP3 (Fibonacci)')
alertcondition((buySignal or sellSignal) and await, title='POETRA Signal', message='POETRA sinyal baru!')
